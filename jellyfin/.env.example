TS_KEY=tskey-auth-change-me
JELLYFIN_HOSTNAME=jellyfin

JELLYFIN_IMAGE_TAG=latest
TAILSCALE_IMAGE_TAG=latest

PUID=1000
PGID=1000
TZ=Etc/UTC
NVIDIA_VISIBLE_DEVICES=all

# Optional volume path overrides. If omitted, compose.yml uses these defaults.
JELLYFIN_CONFIG_PATH=./jellyfin_config
TV_SHOWS_PATH=./media/tvshows
MOVIES_PATH=./media/movies
MUSIC_PATH=./media/music
