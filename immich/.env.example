# You can find documentation for supported env variables at:
# https://docs.immich.app/install/environment-variables

TS_KEY=tskey-auth-change-me
IMMICH_TS_HOSTNAME=photos-v2
TAILSCALE_IMAGE_TAG=latest

# Keep this as a new stack-local path for immich-v2.
# Copy or rsync the old upload backup into this directory before restoring the DB.
UPLOAD_LOCATION=./upload

# Keep this as a new stack-local path for immich-v2.
# Do not point this at the old live database directory.
DB_DATA_LOCATION=./postgres

TZ=America/Puerto_Rico
IMMICH_VERSION=v2

# Please use only A-Za-z0-9 for the database password.
DB_PASSWORD=change-me

DB_USERNAME=postgres
DB_DATABASE_NAME=immich
